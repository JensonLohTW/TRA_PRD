                    },
                    {
                      "type": "text",
                      "id": "G5mFnp",
                      "name": "Paragraph 2",
                      "fill": "$6:--foreground",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "113年度子女教育補助申請即將開始，請有需求之同仁於申請期間內備妥相關文件提出申請。",
                      "lineHeight": 1.8,
                      "fontFamily": "Inter",
                      "fontSize": 15,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "csG6X",
                      "name": "Subheading 1",
                      "fill": "$6:--foreground",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "一、申請資格",
                      "lineHeight": 1.6,
                      "fontFamily": "Inter",
                      "fontSize": 17,
                      "fontWeight": "600"
                    },
                    {
                      "type": "text",
                      "id": "nkLVb",
                      "name": "Bullet 1",
                      "fill": "$6:--foreground",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "• 本會所屬員工，在職滿六個月以上",
                      "lineHeight": 1.8,
                      "fontFamily": "Inter",
                      "fontSize": 15,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "h1xPA3",
                      "name": "Bullet 2",
                      "fill": "$6:--foreground",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "• 子女就讀國內外立案之公私立國小至大專院校",
                      "lineHeight": 1.8,
                      "fontFamily": "Inter",
                      "fontSize": 15,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "ZU8YT",
                      "name": "Bullet 3",
                      "fill": "$6:--foreground",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "• 每位子女每學期以申請一次為限",
                      "lineHeight": 1.8,
                      "fontFamily": "Inter",
                      "fontSize": 15,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "uVM4F",
                      "name": "Subheading 2",
                      "fill": "$6:--foreground",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "二、補助金額",
                      "lineHeight": 1.6,
                      "fontFamily": "Inter",
                      "fontSize": 17,
                      "fontWeight": "600"
                    },
                    {
                      "type": "text",
                      "id": "pQHDy",
                      "name": "Para 1",
                      "fill": "$6:--foreground",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "• 國小/國中：每學期最高補助 NT$3,000",
                      "lineHeight": 1.8,
                      "fontFamily": "Inter",
                      "fontSize": 15,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "VPnCh",
                      "name": "Para 2",
                      "fill": "$6:--foreground",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "• 高中/高職：每學期最高補助 NT$5,000",
                      "lineHeight": 1.8,
                      "fontFamily": "Inter",
                      "fontSize": 15,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "qDLaw",
