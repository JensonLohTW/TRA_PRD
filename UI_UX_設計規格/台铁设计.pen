                    {
                      "type": "text",
                      "id": "Q1ojY",
                      "name": "Method",
                      "fill": "$6:--foreground",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "請登入本系統後，點選「申請補助」→「子女教育補助」，並依系統指示填寫資料及上傳證明文件。",
